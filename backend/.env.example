# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=your_mongodb_uri_here_change_this_in_production
# Production: mongodb+srv://user:password@cluster.mongodb.net/mern-chat

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_REFRESH_EXPIRE=7d

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here_change_this_in_production
OPENAI_MODEL=llama-3.3-70b-versatile

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CHAT_RATE_LIMIT_MAX=30
